{
  "compilerOptions": {
    "declaration": true,
    "allowImportingTsExtensions": false,
    "target": "es2022",
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "esModuleInterop": true,
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"]
    },
    "types": ["node"],
    "lib": ["es2022", "dom"]
  },
  "include": ["src"],
  "exclude": ["node_modules", "**/node_modules/*"]
}
